---
/**
 * On-brand product cover, built from real site assets (Logo + the existing
 * brand street-pattern) rather than a flat raster image - stays crisp at
 * any size and always matches the live brand colors/logo exactly.
 */
import { cn } from '@/lib/cn';
import Logo from '@/components/ui/marketing/Logo/Logo.astro';

interface Props {
  title: string;
  class?: string;
}

const { title, class: className } = Astro.props;
---

<div
  class={cn(
    'relative flex h-full w-full flex-col justify-between overflow-hidden bg-brand-500 p-6',
    className
  )}
>
  <div class="street-pattern-on-brand pointer-events-none absolute inset-0" aria-hidden="true" />

  <div class="relative z-10">
    <div class="inline-flex items-center rounded-lg bg-gray-950 px-3 py-2">
      <Logo variant="full" size="sm" forceDark />
    </div>
    <p class="mt-2 text-xs font-medium text-gray-800">Efficient. Effective. Executed.</p>
  </div>

  <div class="relative z-10 flex flex-1 items-center">
    <div class="rounded-md bg-gray-950 px-4 py-3">
      <p class="font-display text-lg leading-tight font-extrabold text-white sm:text-xl">{title}</p>
    </div>
  </div>
</div>
