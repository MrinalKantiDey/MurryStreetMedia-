---
import Button from '@/components/ui/form/Button/Button.astro';

interface Props {
  slug: string;
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
  class?: string;
}

const { slug, size = 'md', fullWidth = false, class: className } = Astro.props;
---

<Button
  type="button"
  variant="primary"
  size={size}
  fullWidth={fullWidth}
  class={className}
  data-buy-now={slug}
>
  <span data-buy-now-label>Buy Now</span>
</Button>
<p data-buy-now-error={slug} class="mt-2 hidden text-sm text-error" role="alert"></p>

<script>
  function init() {
    document.querySelectorAll<HTMLButtonElement>('[data-buy-now]').forEach((btn) => {
      if (btn.dataset.buyInit) return;
      btn.dataset.buyInit = 'true';

      const slug = btn.dataset.buyNow;
      const label = btn.querySelector<HTMLElement>('[data-buy-now-label]');
      const originalText = label?.textContent ?? 'Buy Now';
      const errorEl = slug
        ? document.querySelector<HTMLElement>(`[data-buy-now-error="${slug}"]`)
        : null;

      btn.addEventListener('click', async () => {
        if (!slug || !label) return;
        errorEl?.classList.add('hidden');
        btn.disabled = true;
        label.textContent = 'Redirecting…';

        try {
          const res = await fetch('/api/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: [{ slug, qty: 1 }] }),
          });
          const data = await res.json();
          if (!res.ok || !data.url) throw new Error(data.error || 'Checkout failed');
          window.location.href = data.url;
        } catch (err) {
          btn.disabled = false;
          label.textContent = originalText;
          if (errorEl) {
            errorEl.textContent =
              err instanceof Error ? err.message : 'Something went wrong. Please try again.';
            errorEl.classList.remove('hidden');
          }
        }
      });
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
