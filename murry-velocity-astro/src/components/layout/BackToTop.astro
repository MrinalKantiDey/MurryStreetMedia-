---
/**
 * BackToTop Component
 * Floating button that appears after scrolling and smooth-scrolls to the top.
 */
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
---

<button
  type="button"
  id="back-to-top"
  class="back-to-top"
  aria-label="Back to top"
>
  <Icon name="arrow-up" size="sm" />
</button>

<script>
  interface BackToTopWindow extends Window {
    __backToTopScrollBound?: boolean;
  }
  const w = window as BackToTopWindow;

  const SHOW_AFTER = 400;

  function initBackToTop() {
    const button = document.getElementById('back-to-top');
    if (!button) return;

    // Re-bound on every page since the button element is replaced by the
    // ClientRouter swap; only one listener per element, so no stacking.
    button.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // The scroll listener itself is bound once ever (window persists across
    // transitions) and always looks up the current live button.
    if (!w.__backToTopScrollBound) {
      w.__backToTopScrollBound = true;
      window.addEventListener(
        'scroll',
        () => {
          const current = document.getElementById('back-to-top');
          if (!current) return;
          current.classList.toggle('back-to-top--visible', window.scrollY > SHOW_AFTER);
        },
        { passive: true }
      );
    }

    button.classList.toggle('back-to-top--visible', window.scrollY > SHOW_AFTER);
  }

  initBackToTop();
  document.addEventListener('astro:page-load', initBackToTop);
</script>

<style>
  .back-to-top {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 49;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    border: 1px solid var(--border);
    background: var(--background);
    color: var(--foreground-muted);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transform: scale(0.8);
    transition:
      opacity var(--transition-normal),
      transform var(--transition-normal),
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .back-to-top--visible {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1);
  }

  .back-to-top:hover {
    color: var(--foreground);
    background: var(--muted);
  }

  .back-to-top:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--background), 0 0 0 4px var(--ring);
  }

  @media (max-width: 640px) {
    .back-to-top {
      right: 0.75rem;
      bottom: 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .back-to-top {
      transition: none;
    }
  }
</style>
